# Copy this file to .env and fill in your values. .env is gitignored — never commit it.

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Image generation model on OpenRouter (examples: openai/gpt-image-1, google/gemini-2.5-flash-image)
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1
